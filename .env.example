# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Fine-grained Personal Access Token with permissions:
#   - Issues: Read and Write
#   - Pull Requests: Read and Write
#   - Contents: Read and Write
#   - Actions: Read
#   - Metadata: Read
GITHUB_TOKEN=ghp_your_fine_grained_pat_here

# Full URL of the GitHub repository
GITHUB_REPO_URL=https://github.com/vasekjanosek/SeriesScraper

# Personal Access Token for self-hosted runner registration
# REQUIRED: Fine-grained PAT with permissions:
#   - Actions: Read and Write (for runner registration)
#   - Administration: Read and Write (for runner management)
# Unlike one-time registration tokens, this PAT persists across container restarts
# Generate at: GitHub Settings > Developer settings > Personal access tokens > Fine-grained tokens
GITHUB_ACCESS_TOKEN=ghp_your_runner_pat_here

# Display name for the self-hosted runner in GitHub UI
RUNNER_NAME=seriescraper-runner

# GitHub username used in escalation comments
GITHUB_USERNAME=vasekjanosek

# ─── Testcontainers (Self-Hosted Runner) ────────────────────────────────────
# Host override for Testcontainers to reach sibling containers from within the runner
# Docker 20.10+ on Linux: host-gateway (auto-resolves to host IP)
# Windows/Mac: host.docker.internal
# If Testcontainers fails to connect, set this to the Docker host IP (e.g., 172.17.0.1)
TESTCONTAINERS_HOST_OVERRIDE=host-gateway

# Ryuk resource reaper configuration
# Ryuk automatically cleans up orphaned Testcontainers after tests complete
# Set to 'true' to disable Ryuk if cleanup is handled manually via 'docker compose down'
# WARNING: Disabling Ryuk may leave orphaned containers if tests crash or are interrupted
TESTCONTAINERS_RYUK_DISABLED=false

# Optional: Override Ryuk container image (useful for private registries)
# Default: testcontainers/ryuk:0.6.0
# TESTCONTAINERS_RYUK_IMAGE=testcontainers/ryuk:0.6.0

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=seriescraper
DB_USER=scraper

# SECURITY: Use a strong random password — NEVER use 'postgres', 'password', or other defaults
# Generate with: openssl rand -base64 32
DB_PASSWORD=CHANGE_ME_USE_STRONG_RANDOM_PASSWORD

DB_HOST=db
DB_PORT=5432

# External port for DB access from host (pgAdmin, DBeaver, etc.)
# SECURITY: PostgreSQL is bound to 127.0.0.1 (loopback only) — not accessible from LAN/WAN
# Access via: psql -h 127.0.0.1 -p 5432 -U scraper -d seriescraper
DB_PORT_EXTERNAL=5432

# ─── Application ─────────────────────────────────────────────────────────────
# Port for the Blazor Server application
APP_PORT=8080

# Application environment: Production | Development | Staging
# DEFAULT: Production — change to Development only for local debugging
APP_ENV=Production

# ASP.NET Core listening URLs — controls which interfaces the app binds to
# - http://+:8080          → All interfaces (0.0.0.0:8080) — use with firewall/VPN only
# - http://localhost:8080  → Loopback only (127.0.0.1:8080) — safest for local-only access
# - http://192.168.1.10:8080 → Specific IP address
ASPNETCORE_URLS=http://+:8080

# ─── Forum Scraper ───────────────────────────────────────────────────────────
# Credentials for the forum being scraped (user has permission)
FORUM_USERNAME=your_forum_username
FORUM_PASSWORD=your_forum_password

# ─── Forum Credential Keys ──────────────────────────────────────────────────
# Each forum in the database stores a credential_key — the name of the env var
# holding that forum's password. Keys MUST match: ^FORUM_[A-Z0-9_]+$
# The app reads Environment.GetEnvironmentVariable(credential_key) at crawl time.
#
# Example: if a forum's credential_key is "FORUM_KINOMANIA_PASSWORD", set:
# FORUM_KINOMANIA_PASSWORD=your_actual_password_here
#
# On startup, the app logs a WARN for every active forum whose env var is missing.
FORUM_BASE_URL=https://your-forum-url.example.com

# ─── IMDB Datasets ───────────────────────────────────────────────────────────
# Path inside the container where IMDB dataset files are stored/cached
# Docker volume: imdb-datasets (created in docker-compose.yml)
# NON-COMMERCIAL USE ONLY — see https://developer.imdb.com/non-commercial-datasets/
#
# Expected disk usage:
# - TSV files (compressed):   ~2-5 GB
# - PostgreSQL with imports:  ~5-15 GB total (postgres_data volume)
# - Total volume storage:     ~10-20 GB
#
# Files downloaded by IMDB import pipeline:
# - title.basics.tsv.gz      ← Movie/TV series metadata
# - title.episode.tsv.gz     ← Episode information
# - title.ratings.tsv.gz     ← IMDB ratings
IMDB_DATASETS_PATH=/app/data/imdb
IMDB_DATA_PATH=/data/imdb

# Default refresh interval in hours (user can override via UI)
IMDB_REFRESH_INTERVAL_HOURS=24

# ─── Scraping Behaviour ──────────────────────────────────────────────────────
# Default request delay range in milliseconds (user can override via UI)
# Absolute limits are defined by PM agent during scope definition
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=8000
