# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Copy to .env and fill in values. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ─── GitHub ──────────────────────────────────────────────────────────────────
# Fine-grained Personal Access Token with permissions:
#   - Issues: Read and Write
#   - Pull Requests: Read and Write
#   - Contents: Read and Write
#   - Actions: Read
#   - Metadata: Read
GITHUB_TOKEN=ghp_your_fine_grained_pat_here

# Full URL of the GitHub repository
GITHUB_REPO_URL=https://github.com/vasekjanosek/SeriesScraper

# Runner registration token — from GitHub Settings > Actions > Runners > New runner
# Tokens expire after 1 hour; re-generate if runner fails to register
GITHUB_RUNNER_TOKEN=your_runner_registration_token_here

# Display name for the self-hosted runner in GitHub UI
RUNNER_NAME=seriescraper-runner

# GitHub username used in escalation comments
GITHUB_USERNAME=vasekjanosek

# ─── Database ────────────────────────────────────────────────────────────────
DB_NAME=seriescraper
DB_USER=scraper
DB_PASSWORD=changeme_use_a_strong_password
DB_HOST=db
DB_PORT=5432

# External port for DB access from host (pgAdmin, DBeaver, etc.)
DB_PORT_EXTERNAL=5432

# ─── Application ─────────────────────────────────────────────────────────────
APP_PORT=8080

# Application environment: Development | Staging | Production
APP_ENV=Development

# ─── Forum Scraper ───────────────────────────────────────────────────────────
# Credentials for the forum being scraped (user has permission)
FORUM_USERNAME=your_forum_username
FORUM_PASSWORD=your_forum_password
FORUM_BASE_URL=https://your-forum-url.example.com

# ─── IMDB Datasets ───────────────────────────────────────────────────────────
# Path inside the container where IMDB dataset files are stored/cached
IMDB_DATA_PATH=/data/imdb

# Default refresh interval in hours (user can override via UI)
IMDB_REFRESH_INTERVAL_HOURS=24

# ─── Scraping Behaviour ──────────────────────────────────────────────────────
# Default request delay range in milliseconds (user can override via UI)
# Absolute limits are defined by PM agent during scope definition
SCRAPE_DELAY_MIN_MS=2000
SCRAPE_DELAY_MAX_MS=8000
